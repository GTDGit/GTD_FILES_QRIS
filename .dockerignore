# Version control metadata
.git
.gitignore
.gitattributes

# Docs (not needed in the build context)
*.md

# Environment files (never bake secrets into the image)
.env
.env.*

# Local secrets / certs (mounted at runtime, not built in)
certs/

# Build output / binaries
bin/
*.exe
*.exe~
gtd_files_qris
*.test
*.out
coverage.out
coverage.html

# IDE / OS noise
.idea/
.vscode/
.DS_Store
Thumbs.db
