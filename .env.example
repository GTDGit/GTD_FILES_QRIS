# files-qris — GTD file-delivery portal (dev-files.gtd.co.id)
# Open upload at /api (no auth) + token-gated, private S3-backed delivery.

# Server
PORT=8090
ENV=development

# Public origin used to build shareable links. Leave empty to derive from the
# incoming request host. Set in prod, e.g. https://dev-files.gtd.co.id
FILES_BASE_URL=https://dev-files.gtd.co.id
# Max size per uploaded file, in MB (default 15).
FILES_MAX_UPLOAD_MB=15

# Database — the portal owns and bootstraps its own tables
# (file_bundles / file_items / file_access_logs) on startup. Can be the shared
# RDS or any Postgres the portal can reach.
DB_HOST=your-rds-endpoint.ap-southeast-3.rds.amazonaws.com
DB_PORT=5432
DB_USER=gtd
DB_PASSWORD=change-me
DB_NAME=gtd
DB_SSLMODE=verify-full
DB_SSLROOTCERT=/app/certs/rds-global-bundle.pem

# Private S3 bucket in the Jakarta region (ap-southeast-3) for Indonesian data
# residency (UU PDP). The bucket MUST block all public access — files are only
# ever streamed back through the token-gated portal, never via a public URL.
FILES_S3_REGION=ap-southeast-3
FILES_S3_BUCKET=gtd-files-dev
# Leave FILES_S3_ENDPOINT empty for real AWS; set it (and use path-style) for MinIO in dev.
FILES_S3_ENDPOINT=
# Prefer an IAM role on the instance over static keys in production. If using
# keys, scope them to s3:PutObject/s3:GetObject/s3:DeleteObject on this bucket only.
FILES_S3_ACCESS_KEY=
FILES_S3_SECRET_KEY=
# Namespace for object keys this portal writes (keep the trailing slash).
FILES_S3_KEY_PREFIX=files/

