# files-qris — QRIS document portal (dev-files-qris.gtd.co.id)
# Token-gated, private S3-backed delivery of merchant onboarding documents.

# Server
PORT=8090
ENV=development

# Database — SAME shared RDS as api/gateway. The portal only reads the
# qris_doc_* tables (migration 000065 lives in api/migrations).
DB_HOST=your-rds-endpoint.ap-southeast-3.rds.amazonaws.com
DB_PORT=5432
DB_USER=gtd
DB_PASSWORD=change-me
DB_NAME=gtd
DB_SSLMODE=verify-full
DB_SSLROOTCERT=/app/certs/rds-global-bundle.pem

# Dedicated S3 bucket for QRIS documents ONLY, in the Jakarta region
# (ap-southeast-3) for Indonesian data residency / UU PDP.
# The bucket MUST block all public access. Files are only ever streamed back
# through the token-gated portal — never via a public URL.
# Use the SAME bucket the gateway uploads to.
FILES_S3_REGION=ap-southeast-3
FILES_S3_BUCKET=gtd-qris-docs-dev
# Leave FILES_S3_ENDPOINT empty for real AWS; set it (and use path-style) for MinIO in dev.
FILES_S3_ENDPOINT=
# Prefer an IAM role on the instance over static keys in production. If using
# keys, scope them to s3:GetObject/s3:DeleteObject on this bucket only.
FILES_S3_ACCESS_KEY=
FILES_S3_SECRET_KEY=
